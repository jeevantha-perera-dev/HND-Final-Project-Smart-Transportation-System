generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum SeatLockStatus {
  ACTIVE
  EXPIRED
  CONSUMED
}

enum TransactionType {
  TOPUP
  PAYMENT
  TRANSFER_IN
  TRANSFER_OUT
  REWARD
  ADJUSTMENT
}

model User {
  id            String               @id @default(cuid())
  fullName      String
  email         String               @unique
  passwordHash  String
  phone         String?
  role          UserRole
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  sessions      Session[]
  wallets       Wallet[]
  tripsAsDriver Trip[]               @relation("TripDriver")
  bookings      Booking[]
  favorites     Favorite[]
  devices       Device[]
  sosEvents     SOSEvent[]           @relation("SOSEventOwner")
  assignments   DriverAssignment[]   @relation("DriverAssignments")
  positions     VehiclePosition[]    @relation("DriverPositions")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  pushToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Stop {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  latitude    Float
  longitude   Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  routeStops  RouteStop[]
}

model Route {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  isExpress   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  routeStops  RouteStop[]
  trips       Trip[]
}

model RouteStop {
  id          String   @id @default(cuid())
  routeId     String
  stopId      String
  stopOrder   Int
  distanceKm  Float?
  route       Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stop        Stop     @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([routeId, stopId])
}

model Vehicle {
  id           String            @id @default(cuid())
  code         String            @unique
  capacity     Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  trips        Trip[]
  positions    VehiclePosition[]
}

model Trip {
  id               String             @id @default(cuid())
  routeId          String
  vehicleId        String
  driverId         String?
  originStopId     String?
  destinationStopId String?
  departureAt      DateTime
  arrivalAt        DateTime?
  baseFare         Decimal            @db.Decimal(10, 2)
  seatsAvailable   Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  route            Route              @relation(fields: [routeId], references: [id], onDelete: Restrict)
  vehicle          Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver           User?              @relation("TripDriver", fields: [driverId], references: [id], onDelete: SetNull)
  bookings         Booking[]
  positions        VehiclePosition[]
  etaSnapshots     EtaSnapshot[]
  progress         TripProgress[]
  assignments      DriverAssignment[]
}

model DriverAssignment {
  id         String   @id @default(cuid())
  driverId   String
  tripId     String
  assignedAt DateTime @default(now())
  driver     User     @relation("DriverAssignments", fields: [driverId], references: [id], onDelete: Cascade)
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String        @id @default(cuid())
  userId       String
  tripId       String
  seatId       String
  status       BookingStatus @default(PENDING)
  totalAmount  Decimal       @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip         Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  ticket       Ticket?
  seatLock     SeatLock?

  @@unique([tripId, seatId])
}

model SeatLock {
  id          String         @id @default(cuid())
  bookingId   String         @unique
  status      SeatLockStatus @default(ACTIVE)
  expiresAt   DateTime
  createdAt   DateTime       @default(now())
  booking     Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  qrCode      String   @unique
  issuedAt    DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Wallet {
  id            String              @id @default(cuid())
  userId        String
  balance       Decimal             @default(0) @db.Decimal(10, 2)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]
  vouchers      Voucher[]
  rewards       Reward[]
}

model WalletTransaction {
  id           String          @id @default(cuid())
  walletId      String
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  reference     String?
  createdAt     DateTime        @default(now())
  wallet        Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Voucher {
  id          String   @id @default(cuid())
  walletId    String
  code        String   @unique
  value       Decimal  @db.Decimal(10, 2)
  expiresAt   DateTime
  redeemedAt  DateTime?
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Reward {
  id          String   @id @default(cuid())
  walletId    String
  title       String
  progress    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  fromPlace   String
  toPlace     String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VehiclePosition {
  id          String   @id @default(cuid())
  tripId      String
  vehicleId   String
  driverId    String?
  latitude    Float
  longitude   Float
  speedKph    Float?
  heading     Float?
  capturedAt  DateTime @default(now())
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver      User?    @relation("DriverPositions", fields: [driverId], references: [id], onDelete: SetNull)
}

model EtaSnapshot {
  id             String   @id @default(cuid())
  tripId          String
  nextStopName    String
  etaMinutes      Int
  seatsAvailable  Int
  createdAt       DateTime @default(now())
  trip            Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TripProgress {
  id          String   @id @default(cuid())
  tripId      String
  status      String
  note        String?
  createdAt   DateTime @default(now())
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Incident {
  id          String   @id @default(cuid())
  tripId      String?
  vehicleId   String?
  title       String
  details     String?
  createdAt   DateTime @default(now())
}

model SOSEvent {
  id             String   @id @default(cuid())
  userId         String
  tripId         String?
  latitude       Float
  longitude      Float
  reverseAddress String?
  createdAt      DateTime @default(now())
  user           User     @relation("SOSEventOwner", fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  body        String
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  resource    String
  resourceId  String?
  metadata    Json?
  createdAt   DateTime @default(now())
}
