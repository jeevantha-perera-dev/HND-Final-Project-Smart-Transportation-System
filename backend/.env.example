NODE_ENV=development
APP_FIREBASE_PROJECT_ID=your-project-id
APP_FIREBASE_WEB_API_KEY=your-firebase-web-api-key
# Preferred: path to the downloaded service account JSON (relative to backend/ when using npm run dev).
APP_FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Alternative: one-line JSON (harder to maintain). File path wins if both are set.
# APP_FIREBASE_SERVICE_ACCOUNT_JSON=
# Emulator-only (remove for cloud):
# APP_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
OSM_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OSM_PHOTON_BASE_URL=https://photon.komoot.io
OSM_ROUTING_BASE_URL=https://router.project-osrm.org
OSM_USER_AGENT=smart-transportation-system/1.0 (contact: dev@smart-transport.local)
OSM_DEFAULT_COUNTRY_CODE=lk
OSM_HTTP_TIMEOUT_MS=10000
OSM_CACHE_TTL_MS=60000
OSM_RETRY_ATTEMPTS=2
OSM_RETRY_BASE_DELAY_MS=350
