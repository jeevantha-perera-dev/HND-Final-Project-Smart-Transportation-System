EXPO_PUBLIC_API_URL=http://127.0.0.1:4000/api/v1
EXPO_PUBLIC_FIREBASE_API_KEY=change-me-firebase-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=smart-transit-local.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=smart-transit-local
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:local
# Omit EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST when using cloud Firebase Auth.
# Optional: point the app at the Firestore emulator (same host:port as firebase.json emulators.firestore).
# EXPO_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
